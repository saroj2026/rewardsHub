// RewardsHub — data model per TRD §6.
// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AuthProvider {
  otp
  google
  apple
  guest
}

enum CardNetwork {
  visa
  mastercard
  rupay
  amex
}

enum RateType {
  flat
  tiered
}

enum CapPeriod {
  monthly
  annual
}

enum DiscountType {
  percentage
  flat_amount
  cashback
}

enum PointBalanceStatus {
  active
  redeemed
  expired
}

model User {
  id           String       @id @default(uuid())
  phone        String?      @unique
  email        String?      @unique
  authProvider AuthProvider @map("auth_provider")
  householdId  String?      @map("household_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  cards         Card[]
  transactions  Transaction[]
  conversations AIConversation[]

  @@map("users")
}

model CardProduct {
  id              String      @id @default(uuid())
  issuer          String
  name            String
  network         CardNetwork
  cardType        String      @map("card_type")
  annualFee       Decimal?    @map("annual_fee")
  benefits        String[]    @default([])
  lastVerifiedAt  DateTime?   @map("last_verified_at")
  sourceConfidence Float?     @map("source_confidence")

  rewardRules RewardRule[]
  cards       Card[]
  offers      Offer[]

  @@map("card_products")
}

model RewardRule {
  id            String    @id @default(uuid())
  cardProductId String    @map("card_product_id")
  cardProduct   CardProduct @relation(fields: [cardProductId], references: [id], onDelete: Cascade)

  category   String
  rateType   RateType  @map("rate_type")
  rateValue  Decimal   @map("rate_value")
  capAmount  Decimal?  @map("cap_amount")
  capPeriod  CapPeriod? @map("cap_period")
  exclusions String[]  @default([])
  validFrom  DateTime  @map("valid_from")
  validTo    DateTime? @map("valid_to")

  @@map("reward_rules")
  @@index([cardProductId])
}

model Merchant {
  id      String   @id @default(uuid())
  name    String
  category String
  mccCode String?  @map("mcc_code")
  aliases String[] @default([])

  offers       Offer[]
  transactions Transaction[]

  @@map("merchants")
}

model Offer {
  id                 String        @id @default(uuid())
  cardProductId      String?       @map("card_product_id")
  cardProduct        CardProduct?  @relation(fields: [cardProductId], references: [id], onDelete: SetNull)
  merchantId         String        @map("merchant_id")
  merchant           Merchant      @relation(fields: [merchantId], references: [id], onDelete: Cascade)

  description        String
  discountType        DiscountType @map("discount_type")
  discountValue       Decimal      @map("discount_value")
  minTransaction      Decimal?     @map("min_transaction")
  requiresEnrollment  Boolean      @default(false) @map("requires_enrollment")
  startsAt            DateTime     @map("starts_at")
  expiresAt           DateTime     @map("expires_at")
  source              String?
  lastVerifiedAt       DateTime?   @map("last_verified_at")

  @@map("offers")
  @@index([merchantId])
  @@index([cardProductId])
}

model Card {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardProductId String   @map("card_product_id")
  cardProduct   CardProduct @relation(fields: [cardProductId], references: [id])

  nickname  String?
  addedAt   DateTime @default(now()) @map("added_at")
  isPrimary Boolean  @default(false) @map("is_primary")

  pointBalances PointBalance[]
  transactions  Transaction[]

  @@map("cards")
  @@index([userId])
}

model PointBalance {
  id            String              @id @default(uuid())
  cardId        String              @map("card_id")
  card          Card                @relation(fields: [cardId], references: [id], onDelete: Cascade)
  pointsBatchId String              @map("points_batch_id")
  amount        Int
  earnedAt      DateTime            @map("earned_at")
  expiresAt     DateTime?           @map("expires_at")
  status        PointBalanceStatus  @default(active)

  @@map("point_balances")
  @@index([cardId])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardId      String   @map("card_id")
  card        Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  merchantId  String?  @map("merchant_id")
  merchant    Merchant? @relation(fields: [merchantId], references: [id], onDelete: SetNull)

  amount      Decimal
  category    String
  gstEligible Boolean  @default(false) @map("gst_eligible")
  enteredAt   DateTime @default(now()) @map("entered_at")

  @@map("transactions")
  @@index([userId])
  @@index([cardId])
}

model AIConversation {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  Json
  createdAt DateTime @default(now()) @map("created_at")

  @@map("ai_conversations")
  @@index([userId])
}
