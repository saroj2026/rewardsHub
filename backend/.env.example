# Copy to .env and fill in real values for anything beyond local dev.
# Local dev defaults below match docker-compose.yml exactly.

# --- Postgres (primary datastore) ---
DATABASE_URL="postgresql://rewardshub:rewardshub_dev@localhost:5432/rewardshub?schema=public"

# --- Redis (cache, rate limiting, BullMQ background jobs) ---
REDIS_URL="redis://localhost:6379"

# --- MinIO now, same S3-compatible API, swap to AWS S3 later by changing only these ---
S3_ENDPOINT="http://localhost:9010"
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID="rewardshub"
S3_SECRET_ACCESS_KEY="rewardshub_dev_secret"
S3_BUCKET="rewardshub-assets"
S3_FORCE_PATH_STYLE="true" # required for MinIO; drop when migrating to real AWS S3

# --- Auth ---
JWT_ACCESS_SECRET="replace-with-a-real-secret"
JWT_REFRESH_SECRET="replace-with-a-different-real-secret"
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=2592000

# --- Phone auth: Firebase Phone Auth (server-side ID token verification) ---
# From Firebase Console → Project Settings → Service Accounts → Generate new private key.
# FIREBASE_PRIVATE_KEY: paste the key from the downloaded JSON with real newlines
# converted to literal "\n" (the app un-escapes them at runtime) — wrap it in quotes.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# --- AI Assistant ---
ANTHROPIC_API_KEY=""

# --- Push notifications ---
FCM_SERVER_KEY=""
APNS_KEY_ID=""
APNS_TEAM_ID=""

PORT=3000
NODE_ENV="development"
